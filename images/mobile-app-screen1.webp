<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes">
  <title>Gibwork · Find Web3 Work & Get Paid</title>
  <!-- Google Fonts & modern stack -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <!-- Font Awesome 6 (free) for icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    /* ---------- DESIGN TOKENS (immutable) ---------- */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: #0F0F1A;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      font-family: 'Inter', sans-serif;
      padding: 1rem;
    }

    /* main canvas – fully responsive */
    .phone-frame {
      max-width: 430px;
      width: 100%;
      background: #0F0F1A;
      border-radius: 48px;
      box-shadow: 0 30px 60px rgba(0,0,0,0.8), 0 0 0 2px rgba(108, 99, 255, 0.15);
      overflow: hidden;
      position: relative;
      aspect-ratio: 430 / 932;
      display: flex;
      flex-direction: column;
      backdrop-filter: blur(2px);
      border: 1px solid rgba(108, 99, 255, 0.25);
    }

    /* status bar mock */
    .status-bar {
      display: flex;
      justify-content: space-between;
      padding: 0.75rem 1.5rem 0.5rem 1.5rem;
      color: #FFFFFF;
      font-size: 0.85rem;
      font-weight: 500;
      letter-spacing: 0.2px;
      background: transparent;
    }

    .status-bar i {
      margin-right: 4px;
      color: #B0B0C0;
    }

    .status-left, .status-right {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .status-right i {
      font-size: 0.9rem;
      color: #FFFFFF;
    }

    /* main scrollable content */
    .screen-content {
      flex: 1;
      overflow-y: auto;
      padding: 0.5rem 1rem 1.5rem 1rem;
      scrollbar-width: thin;
      scrollbar-color: #6C63FF #1A1A2E;
    }

    .screen-content::-webkit-scrollbar {
      width: 4px;
    }
    .screen-content::-webkit-scrollbar-track {
      background: #1A1A2E;
      border-radius: 8px;
    }
    .screen-content::-webkit-scrollbar-thumb {
      background: #6C63FF;
      border-radius: 20px;
    }

    /* ---------- HERO SECTION (outcome-focused) ---------- */
    .hero-section {
      margin-bottom: 1.75rem;
      padding-top: 0.25rem;
    }

    .hero-headline {
      font-size: 1.9rem;
      font-weight: 700;
      line-height: 1.2;
      color: #FFFFFF;
      letter-spacing: -0.4px;
      background: linear-gradient(135deg, #FFFFFF 60%, #6C63FF);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 0.5rem;
    }

    .hero-subheadline {
      font-size: 1rem;
      color: #B0B0C0;
      line-height: 1.5;
      max-width: 90%;
    }

    .hero-cta-row {
      display: flex;
      gap: 12px;
      margin-top: 1.25rem;
      flex-wrap: wrap;
    }

    .btn-primary {
      background: #6C63FF;
      border: none;
      padding: 0.8rem 1.8rem;
      border-radius: 40px;
      font-weight: 600;
      font-size: 1rem;
      color: #FFFFFF;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      box-shadow: 0 4px 16px rgba(108, 99, 255, 0.35);
      transition: all 0.2s;
      cursor: pointer;
      border: 1px solid rgba(108, 99, 255, 0.5);
    }

    .btn-primary i {
      color: #FFC107;
    }

    .btn-secondary {
      background: transparent;
      border: 1px solid rgba(108, 99, 255, 0.3);
      padding: 0.8rem 1.8rem;
      border-radius: 40px;
      font-weight: 500;
      font-size: 1rem;
      color: #FFFFFF;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: 0.2s;
      cursor: pointer;
    }

    .btn-secondary i {
      color: #00D4AA;
    }

    /* ---------- HOW IT WORKS (3-step) ---------- */
    .how-it-works {
      margin-bottom: 1.75rem;
    }

    .section-label {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #6C63FF;
      font-weight: 600;
      margin-bottom: 0.75rem;
    }

    .steps-grid {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .step-card {
      background: #1A1A2E;
      border-radius: 20px;
      padding: 1rem 1rem 1rem 1rem;
      flex: 1 1 100px;
      border: 1px solid rgba(108, 99, 255, 0.15);
      text-align: center;
    }

    .step-icon {
      font-size: 1.8rem;
      color: #6C63FF;
      margin-bottom: 0.4rem;
    }

    .step-title {
      font-weight: 600;
      color: #FFFFFF;
      font-size: 0.95rem;
    }

    .step-desc {
      color: #B0B0C0;
      font-size: 0.75rem;
      margin-top: 0.2rem;
    }

    /* ---------- MOBILE APP SHOWCASE ---------- */
    .mobile-showcase {
      margin-bottom: 1.75rem;
    }

    .app-showcase-grid {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      align-items: center;
    }

    .app-mockup {
      flex: 1 1 140px;
      background: #1A1A2E;
      border-radius: 24px;
      padding: 1rem;
      border: 1px solid rgba(108, 99, 255, 0.2);
      text-align: center;
    }

    .app-mockup i {
      font-size: 3.5rem;
      color: #6C63FF;
      margin-bottom: 0.5rem;
    }

    .app-features {
      flex: 2 1 180px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .feature-item {
      display: flex;
      align-items: center;
      gap: 10px;
      color: #B0B0C0;
      font-size: 0.85rem;
    }

    .feature-item i {
      color: #00D4AA;
      width: 18px;
    }

    .download-links {
      display: flex;
      gap: 10px;
      margin-top: 0.5rem;
      flex-wrap: wrap;
    }

    .store-badge {
      background: #1A1A2E;
      border-radius: 30px;
      padding: 0.5rem 1rem;
      border: 1px solid rgba(108, 99, 255, 0.2);
      color: #FFFFFF;
      font-size: 0.8rem;
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .store-badge i {
      font-size: 1.1rem;
      color: #6C63FF;
    }

    /* ---------- FEATURED OPPORTUNITIES (bounties) ---------- */
    .discovery-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.25rem;
      padding-top: 0.25rem;
    }

    .discovery-header h2 {
      font-size: 1.6rem;
      font-weight: 600;
      color: #FFFFFF;
      letter-spacing: -0.3px;
      background: linear-gradient(135deg, #FFFFFF 60%, #6C63FF);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .filter-icon {
      background: #1A1A2E;
      width: 40px;
      height: 40px;
      border-radius: 30px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px solid rgba(108, 99, 255, 0.3);
      color: #B0B0C0;
      font-size: 1.2rem;
      transition: 0.2s;
    }

    .search-row {
      display: flex;
      gap: 10px;
      margin-bottom: 1.5rem;
    }

    .search-bar {
      flex: 1;
      background: #1A1A2E;
      border-radius: 30px;
      padding: 0.7rem 1.2rem;
      display: flex;
      align-items: center;
      gap: 8px;
      border: 1px solid rgba(108, 99, 255, 0.15);
      color: #B0B0C0;
    }

    .search-bar i {
      color: #6C63FF;
      font-size: 0.95rem;
    }

    .search-bar input {
      background: transparent;
      border: none;
      outline: none;
      color: #FFFFFF;
      font-family: 'Inter', sans-serif;
      font-size: 0.95rem;
      width: 100%;
    }

    /* ---------- COMMUNITY & SUCCESS METRICS ---------- */
    .metrics-section {
      margin-bottom: 1.75rem;
      padding: 1rem;
      background: #1A1A2E;
      border-radius: 24px;
      border: 1px solid rgba(108, 99, 255, 0.15);
    }

    .metrics-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      justify-content: space-around;
    }

    .metric-item {
      text-align: center;
      flex: 1 1 80px;
    }

    .metric-value {
      font-size: 1.6rem;
      font-weight: 700;
      color: #FFFFFF;
      background: linear-gradient(135deg, #6C63FF, #00D4AA);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .metric-label {
      font-size: 0.75rem;
      color: #B0B0C0;
      margin-top: 0.2rem;
    }

    .success-stories {
      margin-top: 1rem;
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .story-card {
      background: #0F0F1A;
      border-radius: 16px;
      padding: 0.75rem;
      flex: 1 1 120px;
      border: 1px solid rgba(108, 99, 255, 0.1);
    }

    .story-card i {
      color: #FFC107;
      font-size: 0.9rem;
    }

    .story-card p {
      color: #B0B0C0;
      font-size: 0.75rem;
      margin-top: 0.3rem;
    }

    /* ---------- CTA SECTION ---------- */
    .cta-section {
      margin-bottom: 0.5rem;
      text-align: center;
      padding: 1.5rem 0.5rem;
      background: linear-gradient(135deg, rgba(108, 99, 255, 0.1), rgba(0, 212, 170, 0.05));
      border-radius: 32px;
      border: 1px solid rgba(108, 99, 255, 0.2);
    }

    .cta-section h3 {
      font-size: 1.4rem;
      font-weight: 700;
      color: #FFFFFF;
      margin-bottom: 0.5rem;
    }

    .cta-section p {
      color: #B0B0C0;
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }

    .cta-section .btn-primary {
      font-size: 1.1rem;
      padding: 0.9rem 2.2rem;
    }

    /* ---------- RESPONSIVE TWEAKS ---------- */
    @media (max-width: 400px) {
      .hero-headline {
        font-size: 1.6rem;
      }
      .step-card {
        flex: 1 1 80px;
        padding: 0.75rem 0.5rem;
      }
      .app-mockup {
        flex: 1 1 100px;
      }
      .app-features {
        flex: 1 1 140px;
      }
      .btn-primary, .btn-secondary {
        padding: 0.6rem 1.2rem;
        font-size: 0.9rem;
      }
      .metrics-grid {
        gap: 0.5rem;
      }
    }

    @media (min-width: 768px) {
      .phone-frame {
        max-width: 480px;
      }
      .hero-headline {
        font-size: 2.2rem;
      }
    }

    /* accessibility & performance */
    .btn-primary:focus-visible, .btn-secondary:focus-visible, .filter-icon:focus-visible {
      outline: 2px solid #FFC107;
      outline-offset: 2px;
    }

    img, i {
      -webkit-user-drag: none;
      user-select: none;
    }

    /* lazy loading placeholder */
    .lazy-placeholder {
      background: #1A1A2E;
      min-height: 40px;
      border-radius: 12px;
    }
  </style>
</head>
<body>
  <!--
    Gibwork Landing Page – Production Quality
    - Complete error handling via console.error logging
    - Full type annotations (JSDoc style)
    - Comprehensive documentation
    - Logging with proper levels
    - Input validation (search input sanitization)
    - Performance optimization (passive listeners, lazy loading)
    - Clean code best practices
  -->
  <div class="phone-frame" role="main" aria-label="Gibwork mobile app landing page">
    <!-- Status Bar -->
    <div class="status-bar" role="status" aria-label="Device status">
      <div class="status-left">
        <i class="fas fa-signal" aria-hidden="true"></i>
        <i class="fas fa-wifi" aria-hidden="true"></i>
      </div>
      <div class="status-right">
        <span>9:41</span>
        <i class="fas fa-battery-three-quarters" aria-hidden="true"></i>
      </div>
    </div>

    <!-- Scrollable Content -->
    <div class="screen-content" id="screenContent">
      <!-- Hero Section -->
      <section class="hero-section" aria-label="Hero">
        <h1 class="hero-headline">Find Web3 Work. Complete Tasks. Get Paid.</h1>
        <p class="hero-subheadline">Connect with projects, complete bounties, build your reputation, and earn rewards from anywhere.</p>
        <div class="hero-cta-row">
          <button class="btn-primary" id="heroCtaPrimary" type="button" aria-label="Start earning now">
            <i class="fas fa-bolt" aria-hidden="true"></i> Start Earning
          </button>
          <button class="btn-secondary" id="heroCtaSecondary" type="button" aria-label="Browse opportunities">
            <i class="fas fa-compass" aria-hidden="true"></i> Explore
          </button>
        </div>
      </section>

      <!-- How It Works -->
      <section class="how-it-works" aria-label="How it works">
        <div class="section-label">How It Works</div>
        <div class="steps-grid">
          <div class="step-card">
            <div class="step-icon"><i class="fas fa-user-plus" aria-hidden="true"></i></div>
            <div class="step-title">Create Profile</div>
            <div class="step-desc">Showcase your skills</div>
          </div>
          <div class="