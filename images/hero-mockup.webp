<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes, viewport-fit=cover">
  <title>Gibwork · Find Web3 Work. Complete Tasks. Get Paid.</title>
  <meta name="description" content="Gibwork – Connect with projects, complete bounties, build reputation, and earn rewards from anywhere. Mobile-first Web3 work platform.">
  <meta name="theme-color" content="#0F0F1A">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" integrity="sha384-k6RqeWeci5ZR/Lv4MR0sA0FfDOM8d7xj1z5l5c5e5e5e5e5e5e5e5e5e5e5e5e5e5e5" crossorigin="anonymous">
  <style>
    /* ===== RESET & BASE ===== */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: #0F0F1A;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      padding: 1rem;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      text-rendering: optimizeLegibility;
    }

    /* ===== MAIN CONTAINER ===== */
    .hero-mockup {
      max-width: 1200px;
      width: 100%;
      background: radial-gradient(circle at 20% 30%, rgba(108, 99, 255, 0.15) 0%, transparent 60%),
                  radial-gradient(circle at 80% 70%, rgba(0, 212, 170, 0.10) 0%, transparent 50%),
                  linear-gradient(145deg, #0F0F1A 0%, #1A1A2E 100%);
      border-radius: 32px;
      padding: 2.5rem 2rem;
      box-shadow: 0 25px 50px -8px rgba(0,0,0,0.6), 0 0 0 1px rgba(108, 99, 255, 0.15);
      position: relative;
      overflow: hidden;
      transition: box-shadow 0.3s ease, transform 0.2s ease;
      border: 1px solid rgba(108, 99, 255, 0.08);
      will-change: transform;
    }

    .hero-mockup::before {
      content: '';
      position: absolute;
      top: -10%;
      right: -5%;
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(0, 212, 170, 0.08) 0%, transparent 70%);
      border-radius: 50%;
      pointer-events: none;
    }

    .hero-mockup::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 40%;
      background: linear-gradient(to top, rgba(15, 15, 26, 0.7) 0%, transparent 90%);
      pointer-events: none;
      z-index: 0;
    }

    .mockup-content {
      position: relative;
      z-index: 2;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 2.5rem 2rem;
    }

    /* ===== LEFT: TEXT ===== */
    .hero-text {
      flex: 1 1 360px;
      min-width: 280px;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(108, 99, 255, 0.18);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
      padding: 0.4rem 1rem 0.4rem 0.8rem;
      border-radius: 40px;
      border: 1px solid rgba(108, 99, 255, 0.25);
      font-size: 0.8rem;
      font-weight: 500;
      color: #B0B0C0;
      letter-spacing: 0.3px;
      margin-bottom: 1.5rem;
      width: fit-content;
    }

    .badge i {
      color: #00D4AA;
      font-size: 0.9rem;
    }

    .hero-text h1 {
      font-family: 'Inter', sans-serif;
      font-weight: 700;
      font-size: clamp(2.2rem, 8vw, 3.5rem);
      line-height: 1.1;
      letter-spacing: -0.02em;
      background: linear-gradient(135deg, #FFFFFF 30%, #B0B0C0 80%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 1rem;
      max-width: 600px;
    }

    .hero-text .subhead {
      font-size: clamp(1rem, 3vw, 1.2rem);
      line-height: 1.5;
      color: #B0B0C0;
      margin-bottom: 2rem;
      max-width: 520px;
      font-weight: 400;
    }

    .hero-cta-group {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      align-items: center;
      margin-top: 0.5rem;
    }

    .btn-primary {
      background: #6C63FF;
      border: none;
      padding: 12px 28px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 1rem;
      color: white;
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      transition: background 0.3s ease, transform 0.2s ease, box-shadow 0.3s ease;
      box-shadow: 0 4px 14px rgba(108, 99, 255, 0.3);
      cursor: pointer;
      border: 1px solid rgba(255,255,255,0.05);
      text-decoration: none;
      -webkit-tap-highlight-color: transparent;
      touch-action: manipulation;
    }

    .btn-primary i {
      font-size: 1rem;
    }

    .btn-primary:hover {
      background: #5a52e0;
      transform: scale(1.02);
      box-shadow: 0 6px 20px rgba(108, 99, 255, 0.4);
    }

    .btn-primary:active {
      transform: scale(0.98);
    }

    .btn-outline {
      background: transparent;
      border: 1px solid rgba(255, 255, 255, 0.15);
      padding: 12px 24px;
      border-radius: 8px;
      font-weight: 500;
      color: #FFFFFF;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      transition: background 0.2s ease, border-color 0.2s ease;
      cursor: pointer;
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
      text-decoration: none;
      -webkit-tap-highlight-color: transparent;
      touch-action: manipulation;
    }

    .btn-outline i {
      color: #00D4AA;
    }

    .btn-outline:hover {
      background: rgba(255,255,255,0.05);
      border-color: rgba(108, 99, 255, 0.4);
    }

    .btn-outline:active {
      background: rgba(255,255,255,0.08);
    }

    .mobile-stats {
      display: flex;
      gap: 1.8rem;
      margin-top: 2.5rem;
      flex-wrap: wrap;
    }

    .stat-item {
      display: flex;
      flex-direction: column;
    }

    .stat-value {
      font-size: 1.6rem;
      font-weight: 600;
      color: #FFFFFF;
      letter-spacing: -0.02em;
      line-height: 1.2;
    }

    .stat-label {
      font-size: 0.8rem;
      color: #B0B0C0;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 500;
    }

    .stat-value small {
      font-size: 0.9rem;
      font-weight: 400;
      color: #00D4AA;
      margin-left: 4px;
    }

    /* ===== RIGHT: PHONE MOCK ===== */
    .hero-visual {
      flex: 1 1 340px;
      min-width: 260px;
      display: flex;
      justify-content: center;
      align-items: center;
      position: relative;
    }

    .phone-mock {
      background: #1A1A2E;
      border-radius: 36px;
      padding: 12px 8px;
      width: 100%;
      max-width: 280px;
      box-shadow: 0 20px 40px -12px rgba(0,0,0,0.7), 0 0 0 1px rgba(108, 99, 255, 0.2);
      border: 1px solid rgba(255,255,255,0.03);
      backdrop-filter: blur(2px);
      -webkit-backdrop-filter: blur(2px);
      transition: transform 0.2s ease;
    }

    .phone-screen {
      background: #0F0F1A;
      border-radius: 28px;
      overflow: hidden;
      padding: 16px 12px 20px;
      border: 1px solid rgba(108, 99, 255, 0.2);
      box-shadow: inset 0 0 30px rgba(0,0,0,0.5);
    }

    .app-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 18px;
      padding: 0 4px;
    }

    .app-header i {
      color: #6C63FF;
      font-size: 1.2rem;
      filter: drop-shadow(0 0 4px rgba(108,99,255,0.3));
    }

    .app-header .wallet {
      background: rgba(108, 99, 255, 0.15);
      padding: 4px 10px;
      border-radius: 30px;
      font-size: 0.65rem;
      font-weight: 600;
      color: #C0C0D0;
    }

    .task-feed {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .task-card {
      background: rgba(255,255,255,0.04);
      border-radius: 14px;
      padding: 12px;
      border: 1px solid rgba(255,255,255,0.03);
      transition: background 0.2s ease;
    }

    .task-card:hover {
      background: rgba(255,255,255,0.06);
    }

    .task-title {
      font-size: 0.8rem;
      font-weight: 600;
      color: #E0E0F0;
      margin-bottom: 4px;
    }

    .task-meta {
      display: flex;
      justify-content: space-between;
      font-size: 0.65rem;
      color: #9090A0;
    }

    .task-meta .reward {
      color: #00D4AA;
      font-weight: 600;
    }

    .task-meta .time {
      color: #707080;
    }

    .app-footer-nav {
      display: flex;
      justify-content: space-around;
      margin-top: 16px;
      padding-top: 12px;
      border-top: 1px solid rgba(255,255,255,0.04);
    }

    .app-footer-nav i {
      color: #505060;
      font-size: 1rem;
      transition: color 0.2s ease;
    }

    .app-footer-nav i.active {
      color: #6C63FF;
    }

    .app-footer-nav i:hover {
      color: #6C63FF;
    }

    /* ===== HOW IT WORKS ===== */
    .how-it-works {
      margin-top: 3rem;
      padding: 2rem 0;
      border-top: 1px solid rgba(108, 99, 255, 0.1);
    }

    .how-it-works h2 {
      font-size: 1.8rem;
      font-weight: 700;
      color: #FFFFFF;
      text-align: center;
      margin-bottom: 2rem;
    }

    .steps-container {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 2rem;
    }

    .step-card {
      flex: 1 1 200px;
      max-width: 280px;
      text-align: center;
      padding: 1.5rem 1rem;
      background: rgba(255,255,255,0.02);
      border-radius: 16px;
      border: 1px solid rgba(108, 99, 255, 0.08);
      transition: transform 0.2s ease, border-color 0.2s ease;
    }

    .step-card:hover {
      transform: translateY(-4px);
      border-color: rgba(108, 99, 255, 0.25);
    }

    .step-icon {
      font-size: 2rem;
      color: #6C63FF;
      margin-bottom: 1rem;
    }

    .step-card h3 {
      font-size: 1.1rem;
      font-weight: 600;
      color: #FFFFFF;
      margin-bottom: 0.5rem;
    }

    .step-card p {
      font-size: 0.9rem;
      color: #B0B0C0;
      line-height: 1.4;
    }

    /* ===== MOBILE APP SHOWCASE ===== */
    .mobile-app-showcase {
      margin-top: 3rem;
      padding: 2rem 0;
      border-top: 1px solid rgba(108, 99, 255, 0.1);
    }

    .mobile-app-showcase h2 {
      font-size: 1.8rem;
      font-weight: 700;
      color: #FFFFFF;
      text-align: center;
      margin-bottom: 2rem;
    }

    .app-features-grid {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1.5rem;
    }

    .feature-card {
      flex: 1 1 180px;
      max-width: 220px;
      text-align: center;
      padding: 1.5rem 1rem;
      background: rgba(255,255,255,0.02);
      border-radius: 16px;
      border: 1px solid rgba(108, 99, 255, 0.08);
      transition: transform 0.2s ease, border-color 0.2s ease;
    }

    .feature-card:hover {
      transform: translateY(-4px);
      border-color: rgba(108, 99, 255, 0.25);
    }

    .feature-icon {
      font-size: 2rem;
      color: #00D4AA;
      margin-bottom: 1rem;
    }

    .feature-card h3 {
      font-size: 1rem;
      font-weight: 600;
      color: #FFFFFF;
      margin-bottom: 0.5rem;
    }

    .feature-card p {
      font-size: 0.85rem;
      color: #B0B0C0;
      line-height: 1.4;
    }

    .download-links {
      display: flex;
      justify-content: center;
      gap: 1rem;
      margin-top: 2rem;
      flex-wrap: wrap;
    }

    .download-btn {
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      padding: 12px 24px;
      border-radius: 8px;
      color: #FFFFFF;
      font-weight: 500;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      transition: background 0.2s ease, border-color 0.2s ease;
      cursor: pointer;
      text-decoration: none;
    }

    .download-btn:hover {
      background: rgba(108, 99, 255, 0.15);
      border-color: rgba(108, 99, 255, 0.3);
    }

    .download-btn i {
      font-size: 1.2rem;
    }

    /* ===== COMMUNITY METRICS ===== */
    .community-metrics {
      margin-top: 3rem;
      padding: 2rem 0;
      border-top: 1px solid